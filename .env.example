# MOMENTUM environment variables
# Copy to .env.local for local dev (vercel dev). NEVER commit .env.local.
# In production, set these in the Vercel dashboard → Project → Settings → Environment Variables.

# --- Claude proxy (api/bobby.js) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase persistence (frontend uses URL + ANON key; both are public-safe) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key

# Service-role key — ONLY if a future serverless function needs to bypass RLS.
# Never expose this to the browser.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key
